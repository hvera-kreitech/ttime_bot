# TrackingTime - Autenticación
# Opción A: App Password (recomendado)
# Crear en: https://app.trackingtime.co/settings/api
TRACKING_TIME_EMAIL=tu_email@ejemplo.com
TRACKING_TIME_PASSWORD=tu_app_password_aqui

# Opción B: API Token (si tu cuenta lo soporta)
# TRACKING_TIME_API_TOKEN=tu_token_aqui

# URL base de la API — incluye el account_id de tu cuenta
# Obtener account_id llamando a GET /me
TRACKING_TIME_BASE_URL=https://api.trackingtime.co/api/v4/TU_ACCOUNT_ID

# Nivel de log (opcional)
# RUST_LOG=ttime_bot=debug
